.hero
    text-align: center

    max-height: 800px

    padding-top: 100px

    overflow: hidden

    background: url(/assets/sourcier/images/trianglify-background.svg) no-repeat

    h2,
    p
        color: heroTextColor
        line-height normal
    h2
        font-size: 31pt
        strong
            font-size 56pt
    p
        font-size: 58pt
        margin-top: -35px

    @media (max-width: mediumScreen - 1)
        h2
            font-size: 13pt;
            strong
                font-size 28pt

        p
            font-size: 32px;
            margin-top: -25px;
